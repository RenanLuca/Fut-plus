generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Position {
  GOALKEEPER
  DEFENDER
  WINGER
  STRIKER
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum Rank {
  BRASILEIRAO
  CHAMPIONS_LEAGUE
  BALLON_DOR
}

enum FrequencyType {
  EVENTUAL
  MONTHLY
}

enum GroupMemberType {
  MONTHLY
  DAILY
  GUEST
  OWNER
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  telefone       String?
  hashedPassword String   @map("hashed_password")
  position       Position
  profilePicture String?  @map("profile_picture")

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  groups              Group[]
  groupMembers        GroupMember[]
  groupMatchPresences GroupMatchPresence[]
  matchTeamPlayers    MatchTeamPlayer[]
  groupPayments       GroupPayment[]

  @@map("users")
}

model GuestUser {
  id        String   @id @default(uuid())
  name      String
  position  Position
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  groupMembers        GroupMember[]
  groupMatchPresences GroupMatchPresence[]
  matchTeamPlayers    MatchTeamPlayer[]

  @@map("guest_users")
}

model Group {
  id           String        @id @default(uuid())
  name         String
  ownerId      String        @map("owner_id")
  weekday      Weekday
  hour         String
  frequency    FrequencyType
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  valuePerUser Float         @map("value_per_user")

  owner         User           @relation(fields: [ownerId], references: [id])
  groupInvites  GroupInvite[]
  groupMatches  GroupMatch[]
  groupMembers  GroupMember[]
  groupPayments GroupPayment[]

  @@map("groups")
}

model GroupMember {
  id          String          @id @default(uuid())
  groupId     String          @map("group_id")
  userId      String?         @map("user_id")
  rank        Rank?
  type        GroupMemberType
  guestUserId String?         @map("guest_user_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  guestUser GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)
  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@unique([groupId, guestUserId])
  @@map("group_members")
}

model GroupInvite {
  id        String   @id @default(uuid())
  groupId   String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_invites")
}

model GroupMatch {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  matchDate DateTime @map("match_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group               Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupMatchPresences GroupMatchPresence[]
  matchTeams          MatchTeam[]

  @@map("group_matches")
}

model GroupMatchPresence {
  id           String   @id @default(uuid())
  groupMatchId String
  userId       String?
  guestUserId  String?  @map("guest_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  groupMatch GroupMatch @relation(fields: [groupMatchId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id])
  guestUser  GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  @@unique([groupMatchId, userId])
  @@unique([groupMatchId, guestUserId])
  @@map("group_match_presences")
}

model MatchTeam {
  id           String   @id @default(uuid())
  groupMatchId String   @map("group_match_id")
  name         String
  color        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  matchTeamPlayers MatchTeamPlayer[]

  groupMatch GroupMatch @relation(fields: [groupMatchId], references: [id], onDelete: Cascade)

  @@map("match_teams")
}

model MatchTeamPlayer {
  id          String   @id @default(uuid())
  matchTeamId String   @map("match_team_id")
  userId      String?  @map("user_id")
  guestUserId String?  @map("guest_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  matchTeam MatchTeam  @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id])
  guestUser GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  @@unique([matchTeamId, userId])
  @@unique([matchTeamId, guestUserId])
  @@map("match_team_players")
}

model GroupPayment {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  period    DateTime
  receipt   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("group_payments")
}
